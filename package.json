{
  "name": "@gahojin-inc/holiday-japanese",
  "version": "2026.4.0",
  "description": "Japanese holidays",
  "author": "GAHOJIN, Inc.",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/gahojin/holiday-japanese.git"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "holidays"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "prepare": "biome migrate --write",
    "prebuild": "tsx scripts/build.ts",
    "build": "rolldown -c",
    "prepublishOnly": "pnpm run build",
    "lint": "biome check --write .",
    "check": "tsgo",
    "check:packagejson": "attw --pack --profile esm-only .",
    "test": "vitest --watch",
    "test:unit": "vitest --passWithNoTests --run --coverage",
    "bench": "vitest bench",
    "ncu": "mise run ncu"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.2",
    "@biomejs/biome": "2.4.12",
    "@holiday-jp/holiday_jp": "2.5.1",
    "@types/japanese-holidays": "1.0.3",
    "@types/node": "24.12.2",
    "@typescript/native-preview": "7.0.0-dev.20260324.1",
    "@vitest/coverage-v8": "4.1.5",
    "japanese-holidays": "1.0.10",
    "jest-extended": "7.0.0",
    "rolldown": "1.0.0-rc.16",
    "rolldown-plugin-dts": "0.23.2",
    "tsx": "4.21.0",
    "vite": "8.0.9",
    "vitest": "4.1.5",
    "yaml": "2.8.3"
  },
  "packageManager": "pnpm@10.33.0"
}
