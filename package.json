{
  "name": "@gahojin-inc/holiday-japanese",
  "version": "2026.5.1",
  "description": "Japanese holidays",
  "author": "GAHOJIN, Inc.",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/gahojin/holiday-japanese.git"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "holidays"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "prepare": "biome migrate --write",
    "prebuild": "tsx scripts/build.ts",
    "build": "vite build",
    "prepublishOnly": "pnpm run build",
    "lint": "biome check --write .",
    "check": "tsc --noEmit",
    "test": "vitest --watch",
    "test:unit": "vitest --passWithNoTests --run --coverage",
    "bench": "vitest bench",
    "ncu": "mise run ncu"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@holiday-jp/holiday_jp": "2.5.1",
    "@types/japanese-holidays": "1.0.3",
    "@types/node": "24.12.4",
    "@vitest/coverage-v8": "4.1.6",
    "japanese-holidays": "1.0.10",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "unplugin-dts": "1.0.0",
    "vite": "8.0.12",
    "vitest": "4.1.6",
    "yaml": "2.9.0"
  },
  "packageManager": "pnpm@11.0.6"
}
