{
  "name": "@gahojin-inc/holiday-japanese",
  "version": "2026.6.0",
  "description": "Japanese holidays",
  "author": "GAHOJIN, Inc.",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/gahojin/holiday-japanese.git"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "holidays"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "prepare": "biome migrate --write",
    "prebuild": "tsx scripts/build.ts",
    "build": "vite build",
    "prepublishOnly": "pnpm run build",
    "lint": "biome check --write .",
    "check": "tsc --noEmit",
    "test": "vitest --watch",
    "test:unit": "vitest --passWithNoTests --run --coverage",
    "bench": "vitest bench",
    "ncu": "mise run ncu"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@holiday-jp/holiday_jp": "catalog:",
    "@types/japanese-holidays": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "japanese-holidays": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "unplugin-dts": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:",
    "yaml": "catalog:"
  },
  "packageManager": "pnpm@11.5.1"
}
